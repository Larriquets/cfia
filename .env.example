ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Express API (default 3000). Must match Vite's proxy — use another value if 3000 is taken by another app.
# PORT=3000

# SQLite path. Local dev:
DATABASE_URL=file:./dev.db
# On Render (with persistent disk mounted at /var/data):
# DATABASE_URL=file:/var/data/cfia.db

# Password to access the CREAR page (story generation).
CREATE_PASSWORD=change-me
